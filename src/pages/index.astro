---
import '../styles/global.css';

const nav = [
  { label: 'Bloom Linkとは', href: '#about' },
  { label: 'できること', href: '#service' },
  { label: '選ばれる理由', href: '#reason' },
  { label: '料金プラン', href: '#price' },
  { label: '制作事例', href: '#works' },
  { label: 'お問い合わせ', href: '#contact' },
];

const aboutChecklist = [
  'お客さまに必要な情報を、必要なときに届ける',
  '来店前から来店後まで、心地よいつながりをつくる',
  'お店の想いが伝わる、あなたらしい仕組みをつくる',
];

const aboutMePhoto = '/images/profile.jpg';

const aboutMeBody = [
  '私は、花屋の家に生まれました。\n小学生の頃からお店を手伝い、気づけばそれが当たり前の毎日になっていました。',
  '正直、しんどいと感じたことも何度もあります。それでも続けてこられたのは、「あなたにお願いしたい」と言ってくださるお客さまがいたからです。',
  '父が引退し、お店を離れることになったときも、「もう少し残ってほしい」と声をかけていただきました。それは、私を頼りにしてくださるお客さまがたくさんいてくださったからでした。',
  'この経験が、今の私の仕事の原点になっています。',
  '私がLINE構築を選んだのは、「作って終わり」の仕事ではないからです。\n構築したあとも、お店に寄り添い、一緒に考え、少しずつ育てていける。そんな長いお付き合いができることに、大きな魅力を感じています。',
  '通り過ぎるだけのご縁ではなく、お店とお客さまのつながりを、時間をかけて育てていきたい。',
  'だから私は、LINEをただの「配信ツール」としてご提案するのではありません。\nお店の想いやお客さまとの関係性を大切にしながら、それぞれのお店に合った「つながりが育つ仕組み」を、一緒につくっていきます。',
  'ご相談は、まだ何も決まっていない段階でも大丈夫です。',
  '「うちの場合はどうしたらいい？」',
  'そんなところから、一緒に考えさせていただけたら嬉しいです。',
];

// ヒーロー右側の画像
const heroPhoto = '/images/hero.jpg';

// 写真ファイルができたら、例: '/images/about-vase.jpg' を設定してください。
// 設定すると、プレースホルダーの枠線・案内文字は自動で消え、実際の写真が表示されます。
const aboutPhoto = '/images/about-soft.png';

// スマホ・LINEアイコン・機能アイコン・装飾をまとめた画像
const servicePhoto = '/images/line-features.jpg';

// 電卓・ノート・植物の世界観写真ができたら、例: '/images/price-scene.jpg' を設定してください。
// 設定すると、プレースホルダーは自動で消えます。
const pricePhoto = '/images/price-photo.jpg';

// Bloom Linkのロゴ（Bと葉っぱ）データができたら設定してください。
// フッターの緑背景になじむよう、白／明るい色のバージョン（透過PNG・SVG推奨）を、
// 例: '/images/logo-mark-white.svg' のように指定してください。
// 設定すると、ブランド名「Bloom Link」の上に自動で表示されます。
const footerLogo = null;

const worries = [
  { no: '01', text: '忙しくて、\n手が回らない', image: '/images/worry1.png' },
  { no: '02', text: 'LINEを始めたけど、\nうまく使えていない', image: '/images/worry2.png' },
  { no: '03', text: '予約や問い合わせの\n管理が大変', image: '/images/worry3.png' },
  { no: '04', text: 'ファンになってもらう\nところまで育てられない', image: '/images/worry4.png' },
];

const services = [
  { title: '予約・受付', desc: '24時間いつでも予約受付。スムーズな予約管理が可能に。' },
  { title: 'クーポン・特典配信', desc: 'クーポンやお知らせを届けて、来店のきっかけをつくる。' },
  { title: '自動応答・チャット', desc: 'よくある質問に自動で対応。お客さまの満足度をアップ。' },
  { title: 'リピート・来店促進', desc: 'お客さま一人ひとりに合った情報を届けて、自然とまた来たくなる関係に。' },
  { title: 'お客さま管理', desc: '属性や来店履歴をもとに、最適な情報を届けることができます。' },
  { title: '分析・顧客管理', desc: 'データを分析して、効果的な改善やサービスの向上につなげる。' },
];

const reasons = [
  { title: '丁寧な\nヒアリング', desc: 'あなたの想いや課題を丁寧にお聞きし、最適な仕組みをご提案します。', icon: '/images/reason1.png' },
  { title: 'オーダーメイド\n設計', desc: 'あなたのお店に合ったLINEの仕組みを、一から設計します。', icon: '/images/reason2.png' },
  { title: '初心者サポート\nが得意', desc: '初めてでも安心。わかるまでやさしくサポートします。', icon: '/images/reason3.png' },
  { title: '運用まで\nしっかりサポート', desc: '構築して終わりではなく、成果につながる運用まで伴走します。', icon: '/images/reason4.png' },
  { title: '継続につながる\n仕組み', desc: 'リピートやファンづくりにつながる仕組みをご提案します。', icon: '/images/reason5.png' },
];

const buildPlans = [
  {
    name: 'LINE公式\nはじめの一歩プラン',
    price: '8万円〜',
    desc: 'まずはLINE公式アカウントを整えて、\n「ちゃんと使える」形に。',
    items: ['初期設定', 'リッチメニュー作成', '予約導線の設置', 'あいさつメッセージ設定'],
    accent: 'sage',
  },
  {
    name: 'LINE＋Lステップ\nスタートプラン',
    price: '10万円〜',
    desc: '予約前後の自動案内や、\nお客様の仕分けの土台まで。',
    items: ['LINE公式の内容すべて', '自動返信の設定', 'タグ設計・仕分けの土台', '予約リマインド設定'],
    accent: 'pink',
    highlight: true,
  },
  {
    name: 'オーダーメイド構築\nしっかり設計プラン',
    price: '18万円〜',
    desc: '導線設計・出し分け・配信設計まで。\n本格的に成果につなげたい方へ。',
    accent: 'dark',
    items: ['LINE＋Lステップの内容すべて', '導線設計・出し分け・配信設計', '出し分け・セグメント配信', '効果測定・改善サポート'],
  },
];

const supportPlans = [
  { name: 'ライトプラン', amount: '8,000', desc: '月1回の配信づくりなど' },
  { name: 'お店を育てるプラン', amount: '12,000', desc: '月2回の配信づくり・分析サポートなど' },
  { name: 'しっかりサポートプラン', amount: '15,000', desc: '月4回の配信・改善提案・サポート充実など' },
];

const works = [
  {
    tag: '制作事例',
    tagStyle: 'solid',
    name: 'るなや',
    sub: '飲食店（居酒屋）',
    desc: '予約・営業情報・アクセスなど、\nお客様が迷わず利用できるLINEを設計しました。',
    photo: '/images/runaya-richmenu.jpg',
  },
  {
    tag: '制作中（進行中）',
    tagStyle: 'pink',
    name: 'ROSA WOOD',
    sub: 'アロマサロン',
    desc: 'ブランドコンセプトからご一緒し、\n世界観を大切にしたLINE構築を進めています。',
    photo: '/images/rosawood.jpg',
    linkLabel: '制作ストーリーを見る',
    linkHref: '/story/rosa-wood',
  },
  {
    tag: 'LINE体験デモ',
    tagStyle: 'soft',
    name: 'Pilates Studio',
    sub: 'Lステップ デモアカウント',
    desc: '実際のLINEの使い心地を体験いただける、\nデモアカウントです。',
    photo: '/images/pilates.jpg',
    qr: '/images/pilates-qr.png',
    linkLabel: 'LINEを体験してみる',
    linkHref: 'https://line.me/ti/p/%40202lchui',
  },
];

const flow = [
  { no: '01', text: 'ご相談・\nお問い合わせ', desc: 'まずはお気軽にご相談ください。', icon: '/images/flow1.png' },
  { no: '02', text: 'ヒアリング', desc: 'お悩みやご希望を丁寧にお伺いします。', icon: '/images/flow2.png' },
  { no: '03', text: 'ご提案・\nお見積り', desc: '最適なプランとお見積りをご提案します。', icon: '/images/flow3.png' },
  { no: '04', text: '制作・構築', desc: 'LINE公式・Lステップを丁寧に構築します。', icon: '/images/flow4.png' },
  { no: '05', text: '運用・\nサポート', desc: '公開後も改善・運用をサポートします。', icon: '/images/flow5.png' },
];

const comingSoon = [
  {
    title: 'LP制作',
    desc: 'ブランドの世界観を大切にした、\n伝わるLP制作も準備中です。',
    note: '※このサイトも、企画からデザイン・制作まで、すべて私が行いました。',
    icon: '/images/coming-lp.png',
  },
  {
    title: 'ブランドデザイン',
    desc: 'ロゴ・名刺・ショップカードなど、\nブランドづくりのお手伝いも準備しています。',
    icon: '/images/coming-brand.png',
  },
];
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bloom Link｜LINEで、また来たくなる仕組みを</title>
    <meta
      name="description"
      content="Bloom Linkは、LINE公式アカウントの構築・運用をサポートするサービスです。予約・リピート・お知らせを、やさしく仕組み化します。"
    />
  </head>
  <body class="bg-cream text-[#3f3a37] font-sans antialiased">
    <!-- ヘッダー -->
    <header class="sticky top-0 z-50 bg-cream/90 backdrop-blur border-b border-sage/10">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
        <a href="#" class="text-lg tracking-widest text-sage font-semibold">Bloom Link</a>
        <nav class="hidden md:flex items-center gap-8 text-sm text-[#5c5450]">
          {nav.map((item) => (
            <a href={item.href} class="hover:text-sage transition-colors">{item.label}</a>
          ))}
        </nav>
        <a
          href="#contact"
          class="text-xs md:text-sm text-cream rounded-full px-5 py-2 bg-gradient-to-b from-[#3f6d55] to-[#2c4a3a] shadow-[inset_0_1px_0_rgba(255,255,255,0.25),0_6px_16px_rgba(47,78,62,0.12)] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.3),0_8px_20px_rgba(47,78,62,0.16)] hover:-translate-y-0.5 transition-all duration-200 whitespace-nowrap"
        >
          無料相談してみる
        </a>
      </div>
    </header>

    <!-- 01 トップ / ヒーロー -->
    <section class="relative overflow-hidden bg-[#FDFBF7]">
      <div class="max-w-6xl mx-auto px-6 pt-10 pb-14 md:pt-14 md:pb-20 grid md:grid-cols-[0.8fr_1.25fr] gap-10 items-center">
        <div>
          <p class="hero-in hero-in-1 text-xs tracking-wider text-sage/70 mb-3">LINE公式アカウントの構築から運用まで</p>
          <h1 class="text-[26px] md:text-[32px] leading-[1.35] tracking-normal">
            <span class="hero-in hero-in-1 block font-medium">お客さまが自然と</span>
            <span class="hero-in hero-in-2 block mt-1 ml-2 md:ml-4 whitespace-nowrap">
              <span class="font-bold text-pink">&quot;また来たくなる&quot;</span><span class="font-medium">仕組みを、</span>
            </span>
            <span class="hero-in hero-in-2 block mt-1 font-medium">LINEで。</span>
          </h1>
          <p class="hero-in hero-in-3 mt-7 text-sm md:text-base text-[#5c5450] leading-relaxed max-w-xs md:max-w-sm">
            予約・リピート・お知らせを、<br class="md:hidden" />
            やさしく仕組み化します。
          </p>
          <a
            href="mailto:bloomlink.01@gmail.com"
            class="hero-in hero-in-4 inline-block mt-8 text-cream rounded-full px-8 py-3 text-sm bg-gradient-to-b from-[#3f6d55] to-[#2c4a3a] shadow-[inset_0_1px_0_rgba(255,255,255,0.25),0_6px_16px_rgba(47,78,62,0.12)] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.3),0_8px_20px_rgba(47,78,62,0.16)] hover:-translate-y-0.5 transition-all duration-200"
          >
            まずは無料で相談してみる
          </a>
        </div>
        <div class="hero-photo-in flex justify-center">
          {heroPhoto ? (
            <img src={heroPhoto} alt="Bloom Linkのイメージ" class="w-full h-auto" />
          ) : (
            <div class="w-full max-w-sm aspect-[4/5] rounded-3xl border-2 border-dashed border-sage/30 bg-white/50 flex items-center justify-center text-center text-sm text-sage/60 p-6">
              ここにスマホ画面とお店の<br />イラストを入れる
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- 02 Bloom Linkとは -->
    <section id="about" class="relative bg-cream overflow-hidden">
      <div class="relative max-w-6xl mx-auto px-6 py-16 md:py-24 grid md:grid-cols-[2fr_3fr] gap-14 md:gap-16 items-center">
        <!-- 写真エリア：写真そのものが空間に置かれているように、カード感を出さない -->
        <div class="reveal relative order-2 md:order-1 mx-auto md:mx-0 w-full">
          {aboutPhoto ? (
            <img src={aboutPhoto} alt="花瓶と植物" class="relative w-full h-auto" />
          ) : (
            <div class="relative w-full aspect-[3/4] rounded-xl border border-dashed border-sage/20 bg-gradient-to-b from-white/50 to-beige/20 flex items-end justify-center overflow-hidden">
              <span class="text-[11px] text-sage/40 mb-3">ここに花瓶と植物の写真を入れる</span>
            </div>
          )}
        </div>

        <!-- 文章エリア：横幅と余白に少しずつ違いをつけて、詰まった印象を避ける -->
        <div class="relative order-1 md:order-2 md:py-10">
          <h2 class="reveal text-xl md:text-2xl font-normal text-sage mb-8 md:mb-10">Bloom Linkとは</h2>
          <p class="reveal text-[#5c5450] leading-[2] mb-10 max-w-md [word-break:keep-all] [overflow-wrap:break-word]">
            <span class="block">Bloom Linkは、</span>
            <span class="block mt-1">LINE公式アカウントの構築を通して、お店とお客さまをつなぎ、関係を育てるお手伝いをします。</span>
          </p>

          <ul class="reveal-stagger space-y-6 mb-10 ml-1 md:ml-2 max-w-sm">
            {aboutChecklist.map((item) => (
              <li class="flex items-start gap-3 text-sm text-[#5c5450]">
                <svg
                  aria-hidden="true"
                  class="mt-0.5 w-4 h-4 shrink-0 text-sage/70"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.3"
                >
                  <path d="M12 20c0-6 3-9 8-11-1 6-3 9-8 11z" />
                  <path d="M12 20c0-6-3-9-8-11 1 6 3 9 8 11z" />
                  <path d="M12 20v-7" />
                </svg>
                <span class="leading-relaxed [word-break:keep-all] [overflow-wrap:break-word]">{item}</span>
              </li>
            ))}
          </ul>

          <p class="reveal text-[#c48f99] leading-[2] max-w-md [word-break:keep-all] [overflow-wrap:break-word]">
            <span class="block">お店の魅力が伝わり、ファンが増え、売上が安定する。</span>
            <span class="block mt-1">そんな未来を、LINEで一緒に実現します。</span>
          </p>
        </div>
      </div>
    </section>

    <!-- 03 こんなお悩み、ありませんか？ -->
    <section id="worry">
      <div class="max-w-6xl mx-auto px-6 py-10 md:py-14">
        <div class="md:flex md:items-start md:gap-16">
          <!-- 左：タイトルと共感の文章 -->
          <div class="md:w-56 md:shrink-0 mb-12 md:mb-0 -mt-2 md:-mt-6">
            <h2 class="reveal text-xl md:text-2xl font-semibold leading-snug mb-4 text-center text-sage">こんなお悩み、<br />ありませんか？</h2>
            <p class="reveal text-[#5c5450] leading-[1.9] text-sm max-w-[260px]">
              <span class="block">知り合いや友人にはSNSで告知しているけれど、思うようにお客様が集まらない。</span>
              <span class="block mt-3">忙しくて手が回らない、そんな方へ。</span>
            </p>
          </div>

          <!-- 右：カードが主役 -->
          <div class="grid grid-cols-2 md:flex md:flex-1 gap-5 md:gap-7">
            {worries.map((w, i) => (
              <div
                class={`relative bg-white rounded-[1.75rem] px-4 pt-9 pb-5 flex flex-col items-center text-center shadow-[0_14px_34px_rgba(53,94,72,0.06)] h-60 md:h-72 md:flex-1 ${
                  i % 2 === 1 ? 'md:translate-x-1 reveal-fade' : 'reveal'
                }`}
                style={`transition-delay: ${i * 0.1}s`}
              >
                <div
                  class={`absolute left-1/2 -translate-x-1/2 w-11 h-11 rounded-full bg-pink text-white flex items-center justify-center text-xs font-medium shadow-[0_6px_14px_rgba(53,94,72,0.08)] ${
                    i % 2 === 1 ? '-top-6' : '-top-4'
                  }`}
                >
                  {w.no}
                </div>
                <p class="text-sm text-[#5c5450] leading-relaxed whitespace-pre-line shrink-0 mb-3">{w.text}</p>
                <div
                  class={`flex-1 w-full min-h-0 flex items-center justify-center px-3 pb-3 ${
                    i === 0 || i === 3 ? 'p-5' : ''
                  }`}
                >
                  <img src={w.image} alt={w.text} class="max-h-full max-w-full object-contain" />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 04 LINEだからできること -->
    <section id="service" class="bg-cream">
      <div class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <h2 class="reveal text-2xl md:text-3xl font-medium mb-2 text-sage">LINEだからできること。</h2>
        <p class="reveal text-sm text-sage/70 mb-2">お店とお客さまを、やさしくつなぐ。</p>
        <p class="reveal text-[#5c5450] leading-loose mb-3 max-w-2xl">
          つながりが、売上を育てる。<br />
          LINEには、お店の未来を変える力があります。
        </p>

        <!-- PC表示：画像を中央に、各機能をアイコンと同じ高さの左右に配置 -->
        <div class="hidden md:flex md:justify-center">
          <div class="reveal relative w-full max-w-[800px]">
            {servicePhoto ? (
              <img
                src={servicePhoto}
                alt="LINEでお店とお客様がつながるイメージ"
                class="w-full h-auto"
              />
            ) : (
              <div class="w-full aspect-[925/588] rounded-[2rem] border border-dashed border-sage/20 bg-gradient-to-b from-beige/30 to-white flex items-center justify-center text-center text-sm text-sage/40 p-6">
                ここにスマホ・LINEアイコン・機能アイコン・装飾をまとめた画像を入れる
              </div>
            )}

            <!-- 左側の機能：カレンダー17%・チケット42%・吹き出し67% の高さに合わせる -->
            <div class="absolute top-[17%] right-full -translate-y-1/2 pr-2 w-[190px] text-right">
              <h3 class="font-medium mb-1 leading-snug text-[15px]">{services[0].title}</h3>
              <p class="text-xs text-[#5c5450] leading-snug">{services[0].desc}</p>
            </div>
            <div class="absolute top-[42%] right-full -translate-y-1/2 pr-2 w-[190px] text-right">
              <h3 class="font-medium mb-1 leading-snug text-[15px]">{services[1].title}</h3>
              <p class="text-xs text-[#5c5450] leading-snug">{services[1].desc}</p>
            </div>
            <div class="absolute top-[67%] right-full -translate-y-1/2 pr-2 w-[190px] text-right">
              <h3 class="font-medium mb-1 leading-snug text-[15px]">{services[2].title}</h3>
              <p class="text-xs text-[#5c5450] leading-snug">{services[2].desc}</p>
            </div>

            <!-- 右側の機能：ハート12%・人43%・グラフ67% の高さに合わせる -->
            <div class="absolute top-[12%] left-full -translate-y-1/2 pl-2 w-[190px] text-left">
              <h3 class="font-medium mb-1 leading-snug text-[15px]">{services[3].title}</h3>
              <p class="text-xs text-[#5c5450] leading-snug">{services[3].desc}</p>
            </div>
            <div class="absolute top-[43%] left-full -translate-y-1/2 pl-2 w-[190px] text-left">
              <h3 class="font-medium mb-1 leading-snug text-[15px]">{services[4].title}</h3>
              <p class="text-xs text-[#5c5450] leading-snug">{services[4].desc}</p>
            </div>
            <div class="absolute top-[67%] left-full -translate-y-1/2 pl-2 w-[190px] text-left">
              <h3 class="font-medium mb-1 leading-snug text-[15px]">{services[5].title}</h3>
